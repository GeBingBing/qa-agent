# =============================================================================
# kb-qa-agent — Provider / MCP / Runtime Configuration
# =============================================================================
# Copy to `.env` and fill in keys you have. Unset keys = provider skipped at runtime.
# The application never panics on missing keys — providers without keys are simply
# unavailable in the registry. See tests/test_providers.py for skip-on-missing behavior.
# =============================================================================

# ---------- Active Provider Selection ----------
# The provider used by the running backend. Override per-request via API.
KB_QA_ACTIVE_PROVIDER=deepseek
KB_QA_ACTIVE_MODEL=deepseek-chat

# ---------- Provider: DeepSeek ----------
# Docs: https://platform.deepseek.com/api-docs/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# ---------- Provider: OpenAI (GPT-4o / o-series) ----------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ---------- Provider: Anthropic (Claude / Opus) ----------
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-8

# ---------- Provider: Moonshot Kimi ----------
# Docs: https://platform.moonshot.cn/docs
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_DEFAULT_MODEL=moonshot-v1-128k

# ---------- Provider: Zhipu GLM (BigModel) ----------
# Docs: https://bigmodel.cn/dev/api
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_DEFAULT_MODEL=glm-4-flash

# ---------- Provider: Alibaba DashScope (Qwen) ----------
# Docs: https://help.aliyun.com/zh/model-studio/developer-reference
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_DEFAULT_MODEL=qwen-plus

# ---------- Provider: MiniMax ----------
# Public docs reference a vendor OpenAI-compatible endpoint; replace with the
# real base_url once your team has signed an agreement.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_DEFAULT_MODEL=abab6.5s-chat

# ---------- MCP Servers ----------
# External MCP: AMap (高德地图)
AMAP_MCP_URL=https://mcp.amap.com/mcp?key=
# Local mock MCP: started by `docker compose up mock-internal-mcp`
INTERNAL_MCP_URL=http://localhost:8765/mcp

# ---------- Vector DB / RAG ----------
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=kb_policies
EMBEDDING_PROVIDER=local            # local | openai | dashscope (TBD)
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ---------- Observability ----------
KB_QA_TRACE_DIR=./.traces
KB_QA_TRACE_LEVEL=INFO               # DEBUG | INFO | WARN | ERROR
KB_QA_COST_REPORT_PATH=./.cost/report.json
# 可选：写 OTel 时 lifespan 自动启用 BatchSpanProcessor + OTLPSpanExporter
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=kb-qa-agent

# ---------- Sandbox (Lesson 12) ----------
KB_QA_SANDBOX_WORKDIR=./data/sandbox_workspace
KB_QA_SANDBOX_TIMEOUT=15
KB_QA_SANDBOX_ALLOWED_CMD_PREFIXES=python3,ls,cat,head,grep

# ---------- FastAPI ----------
KB_QA_API_HOST=0.0.0.0
KB_QA_API_PORT=8000
KB_QA_CORS_ORIGINS=http://localhost:5173
